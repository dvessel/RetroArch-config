#!/usr/bin/env zsh

# output is piped through multiple commands. allow passing exit status for the script.
setopt PIPEFAIL

# commands:
# - init
# - scan
# - repair

local command scandir mamezip samples appendxml preview verbose reset

zparseopts -D -F -E - \
  {z,-mamezip}:=mamezip \
  {s,-samples}:=samples \
  {x,-appendxml}:=appendxml \
  {p,-preview}=preview \
  {v,-verbose}=verbose \
  -reset=reset || return 1

# TODO: handle commands when it's not given but the scandir is.
command=${1:-scan}; shift 2>/dev/null
scandir=${${1:a}:-$PWD}; shift 2>/dev/null

if [[ ! -d $scandir ]]
then
  echo "scan directory doesn't exist." >&2
  return 1
fi

samples=${samples[-1]:a}
mamezip=${${mamezip[-1]:a}:-$XDG_DATA_HOME/advscan/mamezip}
appendxml=${${appendxml[-1]:a}:-$XDG_DATA_HOME/advscan/mamexml/_append}

# Go back to current directory when done.
# advscan can't resolve paths when run outside advscan.rc.
trap 'cd $PWD' INT TERM EXIT

if [[ ! -d $scandir/.advscan ]]
then
  mkdir -p $scandir/.advscan
fi
cd $scandir/.advscan

if [[ $command == init ]]
then
  reset=init
fi

if [[ ! -f advscan.rc || -n $reset ]]
then
  echo "Initial setup…"

cat <<-EOF > advscan.rc
# generated by $0:t
# https://www.advancemame.it/doc-advscan

# List of paths where the roms are placed. These are the zip archives, which are
# modified and fixed.

	rom roms:roms-new

# Single directory where the new created zip archives are placed. It's STRONGLY
# suggested to put this path ALSO in the 'rom' specification. Otherwise at the
# next run the zip archives are recreated.

	rom_new roms-new

# List of directory trees where other roms files are placed. These are used for
# importing rom file missing in rompath. These files are only read and never
# modified in any way. It's very useful to insert here any rom directories of
# any other arcade emulators. When a new game will be supported the rom archive
# will be made automatically.

	rom_import mamezip

# List of paths where the disks are placed. These are the chd archives.
# - $0:t will overwrite disk paths. Subfolders will be added automatically before
#   each scan so it can locate chd files. advscan can only validate disk checksums.

	disk roms

# List of paths where the samples are placed. These are the zip archives, which
# are modified and fixed.

	sample samples

# Single directory where unknown rom zip archives will be moved. In this directory
# is inserted any rom file removed from the rom zip archives. However, any rom
# file is automatically deleted by advscan if it's duplicated in an archive listed
# on the 'rom' or 'rom_import' options.

	rom_unknown mamezip/unknown/roms

# Single path where unknown disk chd archives will be moved.

	disk_unknown mamezip/unknown/disks

# Single path where unknown sample zip archives will be moved. In this directory
# is inserted any sample file removed from the sample zip archives.

	sample_unknown mamezip/unknown/samples

EOF

  if [[ -n $reset ]]
  then
    find . -type l -delete
  fi

  mkdir -p roms-new samples mamexml mamezip/unknown/{roms,disks,samples}

  ln -sF .. roms

  if [[ -d $mamezip ]]
  then
    ln -s $mamezip/* mamezip
  fi
  if [[ -d $appendxml ]]
  then
    ln -s $appendxml mamexml/_append
  fi
  if [[ -d $samples ]]
  then
    ln -sF $samples samples
  fi
fi

# Add disk sub-directories to the advscan.rc file so it can be seen.
local chdir=( ${$(print -- roms/*/(N)):-roms} )
sed -i '' -E "s|^(disk ).*|\1${(j[:])chdir}|" advscan.rc

local mamexml=mamexml/current.xml

if [[ ! -e $mamexml || $scandir -nt $mamexml ]]
then

  if [[ -f $mamexml ]]
  then
    echo "rebuilding xml files..."
  else
    echo "building xml files..."
  fi

  mamexml=mamexml/`mame -version | awk -F'[ .]' '{print $1$2}'`.xml
  ln -sf $mamexml:t mamexml/current.xml

  local all_names=( roms/*.zip*(:t:r:r) )
  # get names to append, specific to the rom directory being scanned.
  local append_all=( mamexml/_append/*.xml(N:t:r) )
  local append_roms=( ${all_names:*append_all} )

  mame -listxml $all_names > $mamexml

  if [[ -n $append_roms ]]
  then
    echo "Appending ${(j/,/)append_roms}..."
    {
      # print main xml file, but omit closing </mame> tag.
      sed '/<\/mame>/d' $mamexml

      for name in $append_roms
      do
        # print `/mame/machine` and omits the following:
        # 1. xml declaration line
        # 2. doctype & specs
        # 3. opening <mame> line
        # 4. closing </mame> line
        sed '/<?xml/d;/<!/d;/]>/d;/<mame/d;/<\/mame>/d' mamexml/_append/$name.xml
      done

      # print the closing tag.
      echo "</mame>"
    } > $mamexml.tmp && mv -f $mamexml.tmp $mamexml
  fi
fi

for p in verbose preview;
do
  if [[ -n ${(P)p} ]]
  then
    command+=-$p
  fi
done

local report_file=`date "+%y%m%d%H%M%S"`-v${$(readlink $mamexml):r}-${command}.txt

mkdir -p reports

# Modes:
#   -r, --rom          Operate on rom sets
#   -s, --sample       Operate on sample sets
#   -k, --disk         Operate on disk files
# Operations:
#   -a, --add-zip      Add missing zips
#   -b, --add-bin      Add missing files in zips
#   -d, --del-zip      Delete unknown zips
#   -u, --del-unknown  Delete unknown files in zips
#   -g, --del-garbage  Delete garbage files
#   -t, --del-text     Delete unused text files
# Shortcuts:
#   -R, --rom-std      Shortcut for -rabdug
#   -S, --sample-std   Shortcut for -sabdug
# Commands:
#   -e, --equal        Print list of roms with equal crc+size
#   -i, --ident FILE   Identify roms by crc and size
#   -b, --bbs          Output a 'files.bbs' for roms .zip
#   -h, --help         Help of the program
#   -V, --version      Version of the program
# Options:
#   -c, --cfg FILE     Select a configuration file
#   -f, --filter FILT  Filter the game list
#   -p, --report       Write a rom based report
#   -P, --report-zip   Write a zip based report
#   -n, --print-only   Only print operations, do nothing
#   -v, --verbose      Verbose output

case $command in
  init)
    return
  ;;
  scan)
    echo "scanning..."
    advscan -rsk -p < mamexml/current.xml | awk '/total_game_rom_dup/{exit} 1'
  ;;
  scan-verbose)
    echo "scanning... (verbose)"
    advscan -rsk -pPv < mamexml/current.xml
  ;;
  repair)
    echo "repairing..."
    advscan -rsk -bugt -v < mamexml/current.xml
  ;;
  repair-preview)
    echo "repairing... (preview)"
    advscan -rsk -bugt --print-only < mamexml/current.xml
  ;;
  cleanup)
    echo "cleaning..."
    advscan -rsk -dugt < mamexml/current.xml
  ;;
  cleanup-preview)
    echo "cleaning... (preview)"
    advscan -rsk -dugt --print-only < mamexml/current.xml
  ;;
  *)
    echo "invalid command." >&2
    return 1
  ;;
esac 2> >( sed -l '/Missing.*sampleof/d' >&2 ) | tee reports/$report_file |
# colorize -p option output. 
# nodump bad/miss : yellow
# rom miss/bad    : red
# various others  : gray
perl -pe '/^([a-z]+_)?(good|bad|miss|text|binary|garbage)/; print (
  ( $1 eq nodump_ and ( $2 eq bad or $2 eq miss ) ) ?
    "\033[0;33m" :
  ( $1 eq rom_ and ( $2 eq miss or $2 eq bad ) ) ?
      "\033[0;31m" :
  ( $2 eq text or $2 eq binary or $2 eq garbage ) ?
      "\033[0;37m" :
      "\033[0m"
)'

# remove empty reports file.
if [[ `wc -l < reports/$report_file` -le 1 ]]
then
  rm reports/$report_file
else
  echo "report generated: $scandir/.advscan/reports/$report_file"
fi

