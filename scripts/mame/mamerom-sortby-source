#!/usr/bin/env zsh
#
# Hardlinks MAME roms to the .sorted directory based on the 'source' key
# within `mame -listxml`. This enables directory based cfg overrides,
# core options and controller remapping. A group of MAME "machines" or
# games for a given source are more likely to share specific settings.
#
# Usage: mamerom-sortby-source [-r|--reset]
#

zparseopts -D -E -F - {r,-reset}=reset

PATH=$( dirname `realpath $0` ):$PATH

local scandir=~/Games/Emulation/Arcade
local sortdir=$scandir/.sorted

if [[ ! -d $scandir ]]
then
  echo "'$scandir' does not exist." >&2
  return 1
elif ! mamerom-info --init $scandir
then
  echo "Failed to initialize." >&2
  return 1
fi

if [[ ! -d $sortdir ]]
then
  mkdir $sortdir
  # exclude from time machine backups.
  tmutil addexclusion $sortdir
fi

if (( ${#reset} ))
then
  rm -rf $sortdir/*(N)
fi

s.print() {
  local c1=00
  case ${1[1]} in
    +)  c1=32 ;;
    -)  c1=33 ;;
  esac
  printf "\e[1;30m%s\e[0m\n  \e[0;${c1}m%s\e[0m%s\n" "$( mamerom-info --get $scandir/$2:t |
    jq -r --arg name $2:t:r '.machine[] | select(.name == $name) | .description'
  )" "$1:" "${2#$scandir/}"
}

for rom in $scandir/*.zip(N)
do

  if ! mamerom-info --exists $rom
  then
    print "unrecognized '$rom'" >&2
    continue
  fi

  if tag -Nlg $rom | grep -q "^Ignore$"
  then
    # when tagged with "Ignore", find in .sorted and remove.
    find $sortdir -type f -name $rom:t | while read -r ignored
    do
      s.print -ignore $ignored
      rm $ignored
    done
    continue
  fi
  # speedup by ignoring roms already hardlined to .sorted.
  if find $sortdir -inum `stat -Lf %i $rom` | grep -q "$rom:t"
  then
    continue
  fi

	read -d '' source rotate < <( mamerom-info --get $rom |
    jq -r --arg name $rom:t:r '.machine[] | select(
		  .name == $name and .isbios != "yes" and .isdevice != "yes"
	  ) | .source, ( [.display] | flatten | .[0] | .rotate )'
  )
  if [[ -z $source ]]
  then
    # skip bios and devices.
    continue
  fi

  container=-${${source:r}/\//-}
  if [[ $rotate =~ (90|270) ]]
  then
    container+='~tate'
  fi
  link=$sortdir/$container/$rom:t
  mkdir -p $link:h
  ln -f $rom $link
  s.print +linked $link

done

# when deleting roms from $scandir, .sorted should follow while ignoring
# dotfiles. must be escaped `\\\.` or it will fail due to the double quoting
# required for variable expansion.
excluded=( $scandir/*.zip(N:t:r) )
if [[ -n $excluded ]]
then
  find -E $sortdir -type f ! -regex ".+/(\\\..+|(${(j:|:)excluded})\.zip)$" |
    while read -r remove
    do
      rm $remove
      print "removed: $remove"
    done
fi
