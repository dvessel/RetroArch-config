#!/usr/bin/env zsh

zparseopts -D -E -F - -debug=debug

path=( $ZSH_SCRIPT:h/bin $path )
config=( ~/Library/Application\ Support/RetroArch/config/retroarch.cfg )
ldir=${$( sed -En 's/^log_dir = "(.+)"/\1/p' $config )/#\~\//$HOME/}

function dprint {
  [[ -n $debug ]] && print -- $@
}
function set_hz {
  local serial=`rascreen --serial`
  print "requested: ${1}Hz"
  if ! type screen-$serial &> /dev/null; then
    print "screen not recognized (serial: $serial)." >&2
  elif hz=`screen-$serial $1`; then
    # Don't block. To be cleaned up later when unloading the running core.
    rascreen --set-hz $hz &
    rsids+=( $! )
  else
    print "unhandled refresh rate (serial: $serial, requested: ${1}hz)." >&2
  fi
}

# Required logging options for the script to function.
typeset -A log_options=(
  frontend_log_level    1
  log_to_file           true
  log_to_file_timestamp false
  log_verbosity         true
)
for k v in ${(@kv)log_options}; do
  sed -i '' "s/^$k =.*/$k = \"$v\"/" $config
done

tail -Fn-1 $ldir/retroarch.log | while read line; do
  # Content load from RetroArch menus.
  # When run from the command line, loads as "[INFO] [Content] Loading content file:"
  # It can depend on the core. Some cores will log both forms. Some will not log it at all.
  # Running from RetroArch's menu system will consistently use "Using content:".
  unset match
  [[ $line =~ '^\[INFO\] \[Core\] Using content: "(.*)"' ]]
  if [[ -n ${match[1]} ]]; then
    dprint -loading-content
    print "loading: ${match[1]/#$HOME/~}"
  fi

  # Initialize loading.
  if [[ $line =~ "Loading dynamic libretro core from:" ]]; then
    dprint -loading-core
    loading=1
    closing=0
    exited=0
    rsids=()
  fi

  if (( loading )); then
    if [[ $line =~ 'Geometry: ([0-9]+x[0-9]+), Aspect: ([0-9]\.[0-9]+), FPS: ([0-9]+\.[0-9]+), Sample rate: ([0-9]+\.[0-9]+)' ]]
    then
      dprint -geometry:${match[1]}
      dprint -aspect:${match[2]}
      dprint -fps:${match[3]}Hz
      dprint -sample-rate:${match[4]}Hz
      # Emulated machine's refresh rate.
      emuhz=${match[3]}
    fi

    if [[ $line =~ '(Timings deviate too much.) Will not adjust. (\(.+\))' ]]; then
      print "Dynamic Rate Control: ${match[1]} ${match[2]}"
    fi
    if [[ $line =~ 'Started synchronous audio driver.' ]]; then
      # When the audio system is ready, the game is ready.
      # Long delays for heavier cores is common.
      dprint -ready
      loading=0
      set_hz $emuhz
    fi
  elif ! (( closing )); then
    if [[ $line =~ 'SET_SYSTEM_AV_INFO: ([0-9]+x[0-9]+), Aspect: ([0-9]\.[0-9]+), FPS: ([0-9]+\.[0-9]+), Sample rate: ([0-9]+\.[0-9]+)' ]]
    then
      # Mid-run refresh rate changes. Mainly applies to MAME.
      if [[ $emuhz != ${match[3]} ]]; then
        dprint -geometry:${match[1]}
        dprint -aspect:${match[2]}
        dprint -fps:${match[3]}Hz
        dprint -sample-rate:${match[4]}Hz
        emuhz=${match[3]}
        set_hz $emuhz
      fi
    fi

    if [[ $line =~ "Unloading core..." ]]; then
      dprint -unloading-core
      closing=1
      if [[ -n $rsids ]]; then
        for pid in $rsids; do
          # Only kill if the PID still exists and is actually rascreen
          if [[ `ps -p $pid -o comm= 2>/dev/null` == rascreen ]]; then
            dprint -kill: $pid
            kill $pid
          fi
        done
        print "refresh rate released."
      fi
    fi
  fi

  if ! (( loading || exited )) && ! pgrep -x RetroArch &> /dev/null; then
    dprint -exit
    exited=1
    # The log gets truncated when RetroArch launches causing tail to miss a few lines.
    # Move it so it creates a new one on next launch. `tail -F` will follow the new file.
    mv -f $ldir/retroarch.log $ldir/retroarch-last.log
  fi
done
